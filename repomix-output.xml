  static String _buildSucKhoeDiemNhayCam(List<String> saoTatAch) {
    if (saoTatAch.any((s) => s.contains('Thái Âm')) || saoTatAch.any((s) => s.contains('Cự Môn'))) {
      return 'Điểm nhạy cảm thường không chỉ nằm ở thân thể mà còn ở tinh thần, giấc ngủ, suy nghĩ và mức độ hấp thụ áp lực.';
    }
    if (saoTatAch.any((s) => s.contains('Thiên Đồng'))) {
