    if (saoPhuThe.any((s) => s.contains('Thái Âm')) || saoPhuThe.any((s) => s.contains('Thiên Đồng'))) {
      traits.add('tình cảm thiên về sự mềm mỏng, cảm xúc và nhu cầu đồng điệu tinh thần');
    }
    if (saoPhuThe.any((s) => s.contains('Tham Lang'))) {
      traits.add('duyên đến khá mạnh, dễ rung động và cũng dễ bị cảm xúc kéo đi nếu thiếu ổn định');
    }
    if (saoPhuThe.any((s) => s.contains('Đào Hoa')) || saoPhuThe.any((s) => s.contains('Hồng Loan'))) {
