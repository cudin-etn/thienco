    }
    return 'Đường tình cảm ở mức trung bình, muốn bền cần dựa vào sự trưởng thành hơn là cảm xúc nhất thời.';
  }

  static String _buildTinhCamMauNguoi(List<String> saoPhuThe) {
    if (saoPhuThe.any((s) => s.contains('Thiên Tướng')) || saoPhuThe.any((s) => s.contains('Thiên Phủ'))) {
      return 'Mẫu người phù hợp thường là người chững, biết giữ lời, có trách nhiệm và không quá thất thường trong cảm xúc.';
    }
    if (saoPhuThe.any((s) => s.contains('Tham Lang')) || saoPhuThe.any((s) => s.contains('Đào Hoa'))) {
