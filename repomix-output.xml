<file path="lib/features/face_scan/logic/face_analyzer.dart">
import 'dart:math';
import 'package:google_mlkit_face_detection/google_mlkit_face_detection.dart';
import 'tuong_so_data.dart';

class FaceAnalyzer {
  // Hàm phân tích Cung Tài Bạch / Trí Tuệ qua Mắt
  static Map<String, dynamic> analyzeEyes(Face face) {
    // Lấy tọa độ điểm neo của Mắt trái và Mắt phải
    final leftEye = face.landmarks[FaceLandmarkType.leftEye];
    final rightEye = face.landmarks[FaceLandmarkType.rightEye];

    // Nếu AI bị mờ, không tìm thấy mắt thì báo lỗi
    if (leftEye == null || rightEye == null) {
      return {
        'icon': '⚠️',
        'title': 'Không nhận diện rõ mắt',
        'desc': 'Vui lòng đưa mặt vào giữa khung hình và đảm bảo đủ ánh sáng.'
      };
    }

    // 1. Dùng định lý Pytago tính khoảng cách thực tế giữa 2 con mắt trên khung hình
    final dx = rightEye.position.x - leftEye.position.x;
    final dy = rightEye.position.y - leftEye.position.y;
    final eyeDistance = sqrt(dx * dx + dy * dy);

    // 2. Lấy chiều rộng tổng thể của khuôn mặt
    final faceWidth = face.boundingBox.width;

    // 3. Tính Tỷ lệ (Khoảng cách mắt / Chiều rộng mặt)
    final ratio = eyeDistance / faceWidth;

    // 4. Đối chiếu tỷ lệ với Từ điển Tướng Số
    // (Thông thường tỷ lệ chuẩn của người Châu Á nằm trong khoảng 0.42 -> 0.46)
    if (ratio > 0.47) {
      return TuongSoData.data['mat_xa_nhau'];
    } else if (ratio < 0.41) {
      return TuongSoData.data['mat_gan_nhau'];
    } else {
      return TuongSoData.data['mat_can_doi'];
    }
  }
}
</file>

