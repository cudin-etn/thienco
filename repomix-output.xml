    }
    return 'Nền tài vận ở mức vừa phải, muốn bền cần đi đường dài và kiểm soát dòng tiền rõ ràng.';
  }

  static String _buildTaiBachCachKiemTien(List<String> saoTai) {
    if (saoTai.any((s) => s.contains('Văn Xương')) || saoTai.any((s) => s.contains('Văn Khúc'))) {
      return 'Tiền bạc cũng có thể đến từ tri thức, kỹ năng chuyên môn, nội dung, tư vấn hoặc công việc đòi hỏi đầu óc.';
    }
    if (saoTai.any((s) => s.contains('Lộc Tồn'))) {
      return 'Lá số có thiên hướng tích góp và tăng tài theo kiểu chậm mà chắc, hợp cách làm đều tay hơn là đánh lớn.';
    }
    if (saoTai.any((s) => s.contains('Thiên Mã'))) {
      return 'Tiền tài dễ mở ra khi di chuyển, mở rộng địa bàn, thay đổi mô hình hoặc làm việc với môi trường linh hoạt.';
    }
    return 'Cách kiếm tiền hợp lá số này là đi theo giá trị thật, tránh ham đường tắt quá nhanh nhưng thiếu nền.';
  }

  static String _buildTaiBachLuuY(List<String> saoTai, int diemTai) {
