    return CungWidget(chi: k.toUpperCase(), tenCung: m12[k] ?? '', chinhTinh: mC[k] ?? [], phuTinh: mP[k] ?? [], tuanTriet: tt, isThan: tb['cungThan'] == k, daiHan: mD[k] ?? 0);
