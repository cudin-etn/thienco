    }
    if (saoPhuThe.any((s) => s.contains('Thất Sát')) || saoPhuThe.any((s) => s.contains('Phá Quân'))) {
      return 'Tình cảm thường không hợp kiểu mập mờ kéo dài; càng rõ ràng, trưởng thành và có nguyên tắc thì càng bền.';
    }
    return 'Trong chuyện tình cảm, điều hợp nhất vẫn là người có khả năng đồng hành lâu dài chứ không chỉ tạo cảm xúc mạnh lúc đầu.';
  }

  static String _buildTinhCamLuuY(List<String> saoPhuThe, int diemPhuThe) {
