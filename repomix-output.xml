    if (saoTai.any((s) => s.contains('Hóa Kỵ'))) {
      cautions.add('sai sót giấy tờ, đầu tư theo cảm xúc hoặc tin người quá nhanh');
    }
    if (saoTai.any((s) => s.contains('Địa Không')) || saoTai.any((s) => s.contains('Địa Kiếp'))) {
      cautions.add('hao hụt bất ngờ, quyết định vội hoặc đánh đổi lớn khi chưa đủ dữ kiện');
    }
    if (saoTai.any((s) => s.contains('Kình Dương')) || saoTai.any((s) => s.contains('Đà La'))) {
      cautions.add('gồng tài chính quá mức hoặc đầu tư cứng tay rồi khó xoay');
    }

    if (cautions.isEmpty) {
      if (diemTai <= -2) {
