import 'package:flutter/material.dart';
import '../../../core/models/user_profile.dart';
import '../../../core/constants/app_colors.dart';
import '../logic/tu_vi_engine.dart';
import '../logic/tu_vi_binh_giai.dart'; 
import 'widgets/cung_widget.dart';
import 'widgets/thien_ban_widget.dart';

class LaSoScreen extends StatelessWidget {
  final UserProfile profile;
  const LaSoScreen({super.key, required this.profile});

  @override
  Widget build(BuildContext context) {
    final isDark = Theme.of(context).brightness == Brightness.dark;
    
    final tbData = TuViEngine.lapThienBan(profile.birthDate, profile.birthTime);
    final String hoTen = profile.name.trim().isEmpty ? 'Đương số' : profile.name;
    final String gioiTinh = profile.isMale ? 'Nam' : 'Nữ';
    final String ngayAm = '${tbData['lunarDay'] ?? '--'}/${tbData['lunarMonth'] ?? '--'}/${tbData['lunarYear'] ?? '----'}';
    final String menhCuc = tbData['menhCuc'] ?? (tbData['cuc'] ?? '');
    final String chiMenh = tbData['cungMenh'] ?? 'Tỵ';
    final m12C = TuViEngine.an12Cung(chiMenh);
    final mCT = TuViEngine.an14ChinhTinh(tbData['lunarDay'] ?? 1, tbData['cuc'] ?? 'Thủy Nhị Cục');
    final mPT = TuViEngine.anPhuTinh(tbData, profile.birthTime);
    final mDH = TuViEngine.tinhDaiHan(tbData['cuc'] ?? 'Thủy Nhị Cục', (tbData['canChiNam'] ?? ' ').split(' ')[0], chiMenh);
    
    // TIỂU HẠN 2026
    final String chiNamSinh = (tbData['canChiNam'] ?? ' ').split(' ')[1];
    final mTH = TuViEngine.tinhTieuHan(chiNamSinh);

    return Scaffold(
      extendBodyBehindAppBar: true,
